# Copy this file to `.env` and fill in your values.
# `.env` is gitignored; never commit it.

# ElevenLabs Scribe API key (used by the transcribe step in batch.py + the
# video-use sibling pipeline). Get one at:
#   https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# Optional: where the sibling `video-use` skill is checked out.
# Default: ../video-use (sibling to this repo).
# VIDEO_USE_DIR=/path/to/video-use

# Optional: override the Python interpreter used by batch.py.
# Default: /opt/homebrew/opt/python@3.12/bin/python3.12
# PYTHON_BIN=python3
